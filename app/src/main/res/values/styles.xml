<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorSecondary">@color/colorPrimaryDark</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <!--        <item name="android:statusBarColor">@color/colorPrimaryDark</item>-->
        <item name="colorAccent">@color/colorAccentDark</item>
    </style>

    <style name="SplashTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@drawable/open_activity_background</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="SplashTheme.MainActivity">
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowTranslucentStatus">false</item>
    </style>

    <style name="NoActionBarTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorSecondary">@color/colorPrimaryDark</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <!--        <item name="android:statusBarColor">@color/colorPrimaryDark</item>-->
        <item name="colorAccent">@color/colorAccentDark</item>
    </style>

    <style name="DialogStyle" parent="@android:style/Theme.Dialog">
        <item name="buttonStyle">@style/ButtonDialogStyle</item>
    </style>

    <style name="ButtonDialogStyle">
        <item name="android:textColor">#00FF00</item>
    </style>

    <style name="NoActionBarTheme.NoStatusBar">
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="GalleryTheme" parent="NoActionBarTheme">
        <!--Есть альтернативный стиль для API >= 23-->
    </style>

    <style name="ToolBarWithNavigationBack">
        <item name="navigationIcon">@drawable/ic_arrow_back</item>
    </style>

    <style name="ToolBarWithNavigationBack.Transparent">
        <item name="navigationIcon">@drawable/abc_ic_ab_back_material</item>
        <item name="windowActionBarOverlay">true</item>
        <item name="android:windowActionBarOverlay">true</item>
    </style>

    <style name="OnboardingTextView" parent="android:Widget.TextView">
        <item name="android:textColor">@color/colorOnboardingText</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">12pt</item>
    </style>

    <style name="FilterTextViewStyle" parent="android:Widget.TextView">
        <item name="android:textColor">@color/colorWhite</item>
        <item name="android:singleLine">true</item>
        <item name="android:ellipsize">end</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">@dimen/text_caption</item>
    </style>

    <style name="FilterGroupText" parent="android:Widget.TextView">
        <item name="android:textColor">@color/colorPrimaryText</item>
        <item name="android:singleLine">true</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">@dimen/text_subtitle</item>
    </style>

    <style name="TitleTextView" parent="android:Widget.TextView">
        <item name="android:textAppearance">@style/MainTextAppearance</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">@dimen/text_header</item>
    </style>

    <style name="SimpleSecondaryText" parent="android:Widget.TextView">
        <item name="android:textSize">@dimen/text_subtitle</item>
        <item name="android:textColor">@color/colorSecondaryText</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_margin">@dimen/margin_xsmall</item>
    </style>

    <style name="SimplePrimaryText" parent="android:Widget.TextView">
        <item name="android:textSize">@dimen/text_subtitle</item>
        <item name="android:textColor">@color/colorPrimaryText</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_gravity">center</item>
    </style>

    <style name="EditItem" />

    <style name="EditItem.LinearLayout">
        <item name="android:padding">@dimen/padding_small</item>
        <item name="android:layout_marginTop">@dimen/margin_small</item>
        <item name="android:layout_marginBottom">@dimen/margin_small</item>
        <item name="android:layout_marginEnd">@dimen/margin_small</item>
        <item name="android:gravity">center</item>
        <item name="android:minWidth">60dp</item>
    </style>

    <style name="EditItem.LinearLayoutRipple" parent="EditItem.LinearLayout">
        <item name="android:background">@drawable/item_ripple</item>
    </style>

    <style name="ShareItem" parent="EditItem.LinearLayout">
        <item name="android:minWidth">0dp</item>
        <item name="android:layout_width">72dp</item>
        <item name="android:layout_height">56dp</item>
    </style>

    <style name="EditItem.LinearLayoutRipple.Oval">
        <item name="android:background">@drawable/item_ripple_oval</item>
    </style>

    <style name="EditItem.ImageView">
        <item name="android:layout_width">@dimen/image_view_side</item>
        <item name="android:layout_height">@dimen/image_view_side</item>
    </style>

    <style name="EditItem.CropImageView">
        <item name="android:layout_width">@dimen/crop_image_view_side</item>
        <item name="android:layout_height">@dimen/crop_image_view_side</item>
    </style>

    <style name="EditItem.TextView">
        <item name="android:textSize">11dp</item>
        <item name="android:textColor">@color/colorPrimaryText</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="EditItem.TextView.TextEdit">
        <item name="fontFamily">@font/roboto_regular</item>
        <item name="textAllCaps">true</item>
        <item name="android:layout_marginTop">10dp</item>
    </style>

    <style name="ShareTextView" parent="EditItem.TextView">
        <item name="android:textAllCaps">false</item>
        <item name="android:layout_marginTop">2dp</item>
    </style>

    <style name="EditText">
        <item name="android:singleLine">true</item>
        <item name="colorControlNormal">#FFFFFF</item>
        <item name="colorControlActivated">#FFFFFF</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:textSize">14sp</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="EditText.TextEditDialog" >
        <item name="android:theme">@style/WhiteColorAccentTheme</item>
    </style>

    <style name="WhiteColorAccentTheme">
        <item name="colorAccent">@color/colorWhite</item>
    </style>

    <style name="MainTextAppearance" parent="TextAppearance.AppCompat">
        <item name="android:textColor">@color/colorTitleText</item>
    </style>

    <style name="SubscriptionRadioButton">
        <item name="android:textColor">@color/colorPrimaryText</item>
        <item name="android:textSize">@dimen/text_title_small</item>
        <item name="android:gravity">center</item>
        <item name="minHeight">50dp</item>
    </style>

    <style name="ToolbarButton">
        <item name="android:textColor">@color/colorBlack</item>
        <item name="android:textSize">@dimen/text_subtitle</item>
        <item name="android:layout_margin">@dimen/margin_normal</item>
        <item name="android:paddingStart">@dimen/padding_normal</item>
        <item name="android:paddingEnd">@dimen/padding_normal</item>
        <item name="android:background">@drawable/item_ripple_oval</item>
    </style>

    <style name="MainActivityLinearLayout">
        <item name="android:background">@drawable/main_button_ripple</item>
        <item name="android:padding">@dimen/padding_normal</item>
        <item name="android:layout_margin">@dimen/margin_large</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <style name="AppTheme.AdAttribution">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">left</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">12sp</item>
        <item name="android:text">@string/save_ad_attribution</item>
        <item name="android:background">#FFCC66</item>
    </style>

    <style name="ColorButton">
        <item name="android:layout_margin">@dimen/margin_small</item>
        <item name="android:layout_width">25dp</item>
        <item name="android:layout_height">25dp</item>
        <item name="cardCornerRadius">256dp</item>
    </style>

    <style name="ColorRadioButton">
        <!--        <item name="android:layout_margin">@dimen/margin_small</item>-->
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:padding">0dp</item>
        <item name="android:layout_marginStart">@dimen/margin_small</item>
        <item name="android:layout_marginEnd">@dimen/margin_small</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="ColorCurveRadioButton" parent="ColorRadioButton">
        <item name="android:layout_width">15dp</item>
        <item name="android:layout_height">15dp</item>
        <item name="android:layout_marginStart">22dp</item>
        <item name="android:layout_marginEnd">22dp</item>
    </style>

    <style name="SelectiveColorViewSliderStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:valueTo">100</item>
        <item name="android:value">0</item>
        <item name="android:valueFrom">-100</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:splitTrack">false</item>
        <item name="haloRadius">0dp</item>
        <item name="thumbColor">@color/colorAccentDark</item>
        <item name="trackColorActive">@android:color/transparent</item>
        <item name="trackColorInactive">@android:color/transparent</item>
    </style>

    <style name="RoundCornerBottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@drawable/rounded_bottom_sheet_dialog_background</item>
    </style>

    <style name="RoundCornerBottomSheetTheme" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/RoundCornerBottomSheetStyle</item>
        <item name="android:windowIsFloating">false</item>
    </style>

    <style name="TransparentBottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="TransparentBottomSheetTheme" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/TransparentBottomSheetStyle</item>
        <item name="android:windowIsFloating">false</item>
    </style>

    <style name="SliderTheme" parent="Theme.MaterialComponents.Light.NoActionBar"/>

</resources>
