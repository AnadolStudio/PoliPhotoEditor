<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="47dp"
    android:layout_height="72dp"
    android:layout_gravity="center"
    android:gravity="center">

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:maxWidth="72dp"
        android:scaleType="centerCrop"
        android:adjustViewBounds="true"
        android:layout_marginBottom="6dp"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:paddingHorizontal="4dp"
        tools:src="@drawable/ic_background_color_button"
        app:layout_constraintBottom_toBottomOf="@+id/support_imageView"
        app:layout_constraintEnd_toEndOf="@+id/support_imageView"
        app:layout_constraintStart_toStartOf="@+id/support_imageView"
        app:layout_constraintTop_toTopOf="@+id/support_imageView"/>

    <ImageView
        android:id="@+id/support_imageView"
        android:layout_width="35dp"
        android:layout_height="wrap_content"
        android:maxWidth="72dp"
        android:layout_marginHorizontal="6dp"
        android:adjustViewBounds="true"
        tools:src="@drawable/ic_background_own_button"
        tools:tint="@color/green"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
