<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="?android:actionBarSize"
    android:elevation="0dp"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent">

    <ImageView
        android:id="@+id/backButton"
        style="@style/ToolbarButton"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:src="@drawable/ic_arrow_back"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/cancelButton"
        style="@style/ToolbarButton"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:src="@drawable/ic_cancel"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/applyButton"
        style="@style/ToolbarButton"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:src="@drawable/ic_accept"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/folderButton"
        style="@style/ToolbarButton"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:src="@drawable/ic_folder"
        app:layout_constraintEnd_toStartOf="@+id/applyButton" />

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/roboto_bold"
        android:text="@string/gallery_title_one_choice"
        android:textColor="@color/colorBlack"
        android:textSize="@dimen/text_subtitle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.Group
        android:id="@+id/group_default_state"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:constraint_referenced_ids="backButton, folderButton" />

    <androidx.constraintlayout.widget.Group
        android:id="@+id/group_selectable_state"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:constraint_referenced_ids="cancelButton, applyButton" />

</androidx.constraintlayout.widget.ConstraintLayout>

